// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}


datasource db {
provider = "mongodb"
}

model Auth {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("auth")
}

model Project {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  slug            String?
  summary         String?
  description     String
  techStack       String[]        @default([])
  tags            String[]        @default([])
  keyFeatures     String[]        
  challenges      String[]        
  repoFrontendUrl String?        
  repoBackendUrl  String?       
  liveUrl         String?         
  thumbnail       String?
  gallery         String[]        @default([])
  status          ProjectStatus   @default(COMPLETED)
  isFeatured      Boolean         @default(true)
  isPublished     Boolean         @default(true)
  startDate      DateTime?
  endDate            DateTime? 
  category        ProjectCategory @relation(fields: [categoryId], references: [id])
  categoryId      String          @db.ObjectId
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([slug])
  @@map("projects")
}

model ProjectCategory {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  project   Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("projectCategories")
}

model Skill {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  icon            String
  level           SkillLevel
  skillCategory   SkillCategory @relation(fields: [skillCategoryId], references: [id])
  skillCategoryId String        @db.ObjectId
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("skills")
}

model SkillCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  skills    Skill[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("skillCategories")
}

model Timeline {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  type          EntryType
  title         String
  organization  String

  startDate     String?
  endDate       String?
  isCurrent     Boolean  @default(false)
  location      String?
  description   String?
  skills        String[]
  tags          String[]

  // Experience fields
  employmentType EmploymentType?
  companyType    CompanyType?
  responsibilities String[]
  achievements     String[]

  // Education fields
  degree          String?
  fieldOfStudy    String?
  grade           String?
  resultType      ResultType?
  activities      String[]
  institutionType InstitutionType?

  // Certification fields
  issuer          String?
  credentialId    String?
  credentialUrl   String?
  issueDate       String?
  expiryDate      String?
  learningType    LearningType?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

    @@map("timelines")
}

model Blog {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  thumbnail  String?
  title      String
  content    String
  category   BlogCategory @relation(fields: [categoryId], references: [id])
  categoryId String       @db.ObjectId
  published  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@map("blogs")
}

model BlogCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blog      Blog[]

  @@map("blogCategories")
}

model Resume {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  url       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("resume")
}

enum ProjectStatus {
  COMPLETED  
  IN_PROGRESS 
  UPCOMING 
  ON_HOLD     
  ARCHIVED  
}

enum SkillLevel {
  Junior
  Intermediate
  Expert
}

enum EntryType {
  EXPERIENCE
  EDUCATION
  CERTIFICATION
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  FREELANCE
  CONTRACT
}

enum CompanyType {
  STARTUP
  AGENCY
  PRODUCT
  RESEARCH
}

enum ResultType {
  CGPA
  GPA
  PERCENTAGE
}

enum InstitutionType {
  SCHOOL
  COLLEGE
  UNIVERSITY
}

enum LearningType {
  COURSE
  BOOTCAMP
  WORKSHOP
  TRAINING
}